<!-- 粒子背景层 -->
<view class="particle-bg">
  <view class="particle p1"></view>
  <view class="particle p2"></view>
  <view class="particle p3"></view>
  <view class="particle p4"></view>
  <view class="particle p5"></view>
  <view class="particle p6"></view>
  <view class="particle p7"></view>
  <view class="particle p8"></view>
</view>

<!-- 装饰圆环 -->
<view class="deco-ring ring-1"></view>
<view class="deco-ring ring-2"></view>
<view class="deco-ring ring-3"></view>

<view class="login-page">

  <!-- 品牌区 -->
  <view class="brand-zone">
    <view class="logo-wrap">
      <view class="logo-glow"></view>
      <view class="logo-inner">
        <text class="logo-emoji">🍔</text>
      </view>
    </view>
    <text class="brand-name">极速外卖</text>
    <text class="brand-slogan">美味 · 即刻送达</text>
  </view>

  <!-- 主卡片 -->
  <view class="login-card">

    <!-- 角色切换 -->
    <view class="role-switch">
      <view class="role-bg {{role === 'delivery' ? 'slide' : ''}}"></view>
      <view class="role-option {{role === 'user' ? 'on' : ''}}" bindtap="switchRole" data-role="user">
        <text class="role-icon">🧑</text>
        <text>用户</text>
      </view>
      <view class="role-option {{role === 'delivery' ? 'on' : ''}}" bindtap="switchRole" data-role="delivery">
        <text class="role-icon">🏍️</text>
        <text>骑手</text>
      </view>
    </view>

    <!-- 登录方式标签 -->
    <view class="mode-tabs">
      <view class="mode-tab {{loginMode === 'sms' ? 'active' : ''}}" bindtap="switchLoginMode" data-mode="sms">
        验证码登录
        <view class="tab-line" wx:if="{{loginMode === 'sms'}}"></view>
      </view>
      <view class="mode-tab {{loginMode === 'password' ? 'active' : ''}}" bindtap="switchLoginMode" data-mode="password">
        密码登录
        <view class="tab-line" wx:if="{{loginMode === 'password'}}"></view>
      </view>
    </view>

    <!-- 输入区 -->
    <view class="input-zone">
      <!-- 手机号 -->
      <view class="input-row">
        <view class="input-prefix">+86</view>
        <input
          class="input-field"
          type="number"
          placeholder="手机号码"
          placeholder-class="placeholder-style"
          maxlength="11"
          bindinput="onPhoneInput"
          value="{{phone}}"
        />
        <view class="input-underline"></view>
      </view>

      <!-- 验证码模式 -->
      <view class="input-row" wx:if="{{loginMode === 'sms'}}">
        <input
          class="input-field flex-1"
          type="number"
          placeholder="验证码"
          placeholder-class="placeholder-style"
          maxlength="6"
          bindinput="onCodeInput"
          value="{{code}}"
        />
        <view class="sms-btn {{counting ? 'disabled' : ''}}" bindtap="sendCode">
          <text wx:if="{{!counting}}">获取验证码</text>
          <text wx:else>{{countdown}}s</text>
        </view>
        <view class="input-underline"></view>
      </view>

      <!-- 密码模式 -->
      <view class="input-row" wx:if="{{loginMode === 'password'}}">
        <input
          class="input-field"
          type="{{showPassword ? 'text' : 'password'}}"
          placeholder="登录密码"
          placeholder-class="placeholder-style"
          bindinput="onPasswordInput"
          value="{{password}}"
        />
        <view class="sms-btn" bindtap="toggleShowPassword">
          {{showPassword ? '🙈' : '👁️'}}
        </view>
        <view class="input-underline"></view>
      </view>
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn-wrap">
      <view class="login-btn" bindtap="handleLogin">
        <text class="btn-text">{{loginMode === 'password' ? '登 录' : '登录 / 注册'}}</text>
        <view class="btn-shine"></view>
      </view>
      <!-- 波纹 -->
      <view class="btn-ripple"></view>
    </view>

    <!-- 底部提示 -->
    <view class="card-footer">
      <text wx:if="{{loginMode === 'sms'}}">未注册手机号验证后自动创建账号</text>
      <text wx:if="{{loginMode === 'password'}}">新用户默认密码 123456</text>
    </view>
  </view>

  <!-- 底部 -->
  <view class="bottom-text">
    <text>登录即表示同意 <text class="link">《用户协议》</text> 和 <text class="link">《隐私政策》</text></text>
  </view>
</view>
