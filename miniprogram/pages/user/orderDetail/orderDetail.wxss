.pb-120 { padding-bottom: 120rpx; }

/* 状态头部 */
.status-header {
  padding: 40rpx 30rpx;
}
.status-title { font-size: 44rpx; }
.action-row { justify-content: flex-start; }
.btn-outline {
  border: 1rpx solid #ccc;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin-right: 20rpx;
  background: #fff;
}

/* 骑手卡片 */
.delivery-card { align-items: center; padding: 30rpx; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #f0f0f0; }
.call-icon { font-size: 40rpx; padding: 10rpx; background: #f5f5f5; border-radius: 50%; }

/* 商品卡片复用 order.wxss 结构 */
.goods-card, .info-card, .rate-card { padding: 30rpx; }
.shop-name { font-size: 32rpx; align-items: center; }
.call-icon-small { font-size: 28rpx; }
.goods-item { margin-bottom: 30rpx; }
.goods-img { width: 110rpx; height: 110rpx; border-radius: 8rpx; margin-right: 20rpx; background: #f0f0f0; }
.goods-info { height: 110rpx; justify-content: center; }
.total-price { color: #ee0a24; font-size: 36rpx; }

/* 评价模块 */
.rate-card { align-items: center; }
.star-wrap { justify-content: center; width: 100%; gap: 20rpx; }
.star { font-size: 60rpx; color: #e0e0e0; transition: color 0.3s; }
.star.active { color: #faad14; }
.rate-input {
  width: 100%; height: 160rpx;
  background: #f9f9f9; border-radius: 12rpx;
  padding: 20rpx; font-size: 26rpx;
  box-sizing: border-box;
}
.submit-rate { width: 80%; border-radius: 40rpx; padding: 20rpx 0; }

.info-item { line-height: 1.4; }