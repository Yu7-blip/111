/* ==================== 吸顶 Tab 栏 ==================== */
.container { padding-top: 90rpx; background: linear-gradient(180deg, #f0f2f5, #f7f8fa); min-height: 100vh; }
.tabs {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #fff; z-index: 100;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  display: flex;
}
.tab-item {
  flex: 1; text-align: center; line-height: 88rpx;
  font-size: 28rpx; color: #888; font-weight: 500;
}
.tab-item.active {
  color: #ff4757;
  font-weight: 700;
  position: relative;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  border-radius: 3rpx;
}

/* ==================== 订单列表 ==================== */
.order-list { padding: 20rpx 24rpx; }
.order-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}
.shop-logo {
  width: 56rpx; height: 56rpx;
  border-radius: 14rpx; margin-right: 14rpx;
  background: #f5f5f5;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.shop-name { font-size: 30rpx; font-weight: 600; margin-right: 8rpx; }
.arrow { font-size: 24rpx; color: #ccc; }
.order-status { font-size: 26rpx; font-weight: 600; }

.order-body { padding: 20rpx 0; }
.goods-desc {
  color: #555;
  font-size: 28rpx;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部按钮 */
.order-footer { justify-content: flex-end; gap: 12rpx; }
.btn-outline {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid #ddd;
  color: #666;
  background: #fff;
}
.btn-outline.btn-refund {
  border-color: #ff6b6b;
  color: #ff6b6b;
}
.btn-primary-small {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255,71,87,0.2);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

/* ==================== 骑手端样式 ==================== */
.task-list { padding: 0 24rpx; }
.task-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.task-actions { align-items: flex-end; flex-shrink: 0; }
.tag {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}
.pickup-tag {
  color: #ff4757;
  background: rgba(255,71,87,0.08);
}
.delivering-tag {
  color: #52c41a;
  background: rgba(82,196,26,0.08);
}
.btn-outline-small {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
  border: 2rpx solid #ddd;
  color: #666;
  text-align: center;
  background: #fff;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  padding: 24rpx 28rpx 12rpx;
}
