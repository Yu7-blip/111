.pay-option {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  margin: 0 10rpx;
  color: #666;
  font-size: 28rpx;
}

.pay-option:first-child {
  margin-left: 0;
}

.pay-option:last-child {
  margin-right: 0;
}

.pay-option.active {
  border-color: #07c160;
  color: #07c160;
  background: rgba(7, 193, 96, 0.05);
}

.pay-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
