<view class="container">
  <view class="card address-card flex-row space-between" bindtap="chooseAddress">
    <view class="flex-col" wx:if="{{address}}">
      <text class="font-bold font-32">{{address.detail}}</text>
      <text class="text-gray font-28 mt-10">{{address.name}} {{address.phone}}</text>
    </view>
    <view class="flex-col" wx:else>
      <text class="font-bold font-32">请选择收货地址</text>
    </view>
    <text class="arrow text-gray">></text>
  </view>

  <view class="card goods-card">
    <view class="shop-name font-bold">{{shop.name}}</view>
    <view class="divider"></view>
    
    <view class="goods-item flex-row mt-20" wx:for="{{cartList}}" wx:key="id">
      <image class="goods-img" src="{{item.image || '/images/default/food.png'}}" mode="aspectFill"></image>
      <view class="goods-info flex-col flex-1 space-between">
        <text class="font-bold">{{item.name}}</text>
        <view class="flex-row space-between">
          <text class="text-gray">x{{item.count}}</text>
          <text class="font-bold">¥{{item.price}}</text>
        </view>
      </view>
    </view>
    
    <view class="divider"></view>
    <view class="fee-item flex-row space-between mt-20">
      <text class="font-28">配送费</text>
      <text class="font-bold">¥{{shop.deliveryFee}}</text>
    </view>
    <view class="fee-item flex-row space-between mt-20" wx:if="{{activityDiscount > 0}}">
      <text class="font-28 text-primary">满减优惠</text>
      <text class="font-bold text-primary">-¥{{activityDiscount}}</text>
    </view>
  </view>

  <view class="card coupon-section">
    <text class="font-bold font-28">选择优惠券</text>
    <view class="coupon-scroll mt-20" wx:if="{{coupons.length > 0}}">
      <view
        wx:for="{{coupons}}"
        wx:key="id"
        class="coupon-card-item {{item.selected ? 'selected' : ''}} {{!item.usable ? 'disabled' : ''}}"
        bindtap="selectCoupon"
        data-index="{{index}}"
      >
        <view class="c-amount-block">
          <text class="c-currency">¥</text>
          <text class="c-value">{{item.reduceAmount}}</text>
        </view>
        <view class="c-info">
          <text class="c-name">{{item.name}}</text>
          <text class="c-condition">满{{item.conditionAmount}}可用</text>
          <text class="c-tip" wx:if="{{!item.usable}}">不满足使用条件</text>
        </view>
        <view class="c-check" wx:if="{{item.usable}}">
          <view class="check-circle {{item.selected ? 'checked' : ''}}">
            <text wx:if="{{item.selected}}" class="check-mark">✓</text>
          </view>
        </view>
      </view>
    </view>
    <view class="flex-row space-between mt-20" wx:else>
      <text class="text-gray font-24">暂无可用优惠券</text>
      <text class="font-24 text-primary" bindtap="goGetCoupons">去领券 ></text>
    </view>
  </view>

  <view class="bottom-bar flex-row space-between">
    <view class="price-wrap ml-20">
      <text class="font-28">合计：</text>
      <text class="total-price font-bold">¥{{finalPrice}}</text>
      <text class="font-24 text-primary ml-10" wx:if="{{discountAmount > 0}}">已优惠¥{{discountAmount}}</text>
    </view>
    <view class="submit-btn" bindtap="submitOrder">提交订单</view>
  </view>
</view>