/* 容器 */
.profile-container {
  padding: 0;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f2f5 0%, #f7f8fa 100%);
}

/* ==================== 头部 ==================== */
.user-header {
  background: linear-gradient(160deg, #ff6b6b 0%, #ee5a24 50%, #ff4757 100%);
  padding: 60rpx 36rpx 120rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}
.user-header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -40rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}
.user-header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 50%;
}
.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.15);
  background: #f0f0f0;
  position: relative;
  z-index: 1;
}
.user-info {
  position: relative;
  z-index: 1;
}
.nickname {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.phone {
  opacity: 0.85;
  font-size: 26rpx;
}

/* ==================== 资产卡片（悬浮） ==================== */
.asset-card {
  margin: -50rpx 28rpx 24rpx;
  padding: 36rpx 16rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.06),
              0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  position: relative;
  z-index: 10;
}
.asset-item {
  align-items: center;
  border-right: 1rpx solid #f0f0f0;
}
.asset-item:last-child { border-right: none; }
.asset-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.asset-name {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* ==================== 菜单列表 ==================== */
.menu-list {
  background: #fff;
  margin: 0 28rpx;
  border-radius: 24rpx;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.menu-item {
  padding: 32rpx 0;
  background: transparent;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
}
.menu-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.arrow {
  font-size: 28rpx;
  color: #ccc;
  font-weight: 300;
}

/* ==================== 退出按钮 ==================== */
.logout-btn {
  margin: 48rpx 28rpx 30rpx;
  background: #fff;
  color: #ff4757;
  text-align: center;
  padding: 30rpx 0;
  font-weight: 600;
  font-size: 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}
