/* ==================== 标签栏 ==================== */
.tabs {
  background: #fff;
  display: flex;
  padding: 8rpx 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  padding: 24rpx 36rpx;
  font-size: 30rpx;
  color: #999;
  font-weight: 500;
  position: relative;
}
.tab-item.active {
  color: #ff4757;
  font-weight: 700;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  border-radius: 3rpx;
}

/* ==================== 列表 ==================== */
.coupon-list {
  padding: 20rpx 24rpx;
}

/* ==================== 优惠券卡片 ==================== */
.coupon-card-item {
  background: #fff;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  position: relative;
}
.coupon-card-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #ff6b6b, #ff4757);
  border-radius: 3rpx 0 0 3rpx;
}

.c-left {
  width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-right: 20rpx;
  border-right: 2rpx dashed #ffe0c0;
  flex-shrink: 0;
}
.c-amount {
  font-size: 48rpx;
  font-weight: 800;
  color: #ff4757;
  line-height: 1.1;
}
.c-amount::before {
  content: '¥';
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 2rpx;
}

.c-right {
  flex: 1;
  padding-left: 20rpx;
  overflow: hidden;
}

/* 领取按钮 */
.btn-get {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4757 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 71, 87, 0.25);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
