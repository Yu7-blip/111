.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.address-card {
  margin: 20rpx 30rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.default-tag {
  color: #ff6b6b;
  background-color: rgba(255, 107, 107, 0.1);
  border: 1rpx solid #ff6b6b;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.action-btn {
  font-size: 22rpx;
  color: #666;
  padding: 4rpx 8rpx;
}
.action-btn.delete-btn {
  color: #ff6b6b;
}

.arrow {
  font-size: 32rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.empty-state {
  align-items: center;
  padding-top: 200rpx;
}
.empty-icon {
  font-size: 80rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.add-btn {
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
}

.mt-10 { margin-top: 10rpx; }
.font-26 { font-size: 26rpx; }
.font-28 { font-size: 28rpx; }
.font-30 { font-size: 30rpx; }
.text-gray { color: #999; }
.font-bold { font-weight: bold; }
