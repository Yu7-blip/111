/* ==================== 首页头部 ==================== */
.header {
  padding: 16rpx 24rpx 24rpx;
  background: linear-gradient(180deg, #ff6b6b 0%, #ff5a5a 100%);
  position: sticky;
  top: 0;
  z-index: 100;
}
.location {
  max-width: 45%;
  color: #fff;
  font-size: 30rpx;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 40rpx;
  backdrop-filter: blur(10px);
}
.location .arrow {
  color: rgba(255,255,255,0.8);
  margin-left: 8rpx;
  font-size: 22rpx;
}
.search-box {
  background: #fff;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  flex: 1;
  margin-left: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.10);
}
.search-box input {
  margin-left: 10rpx;
  font-size: 26rpx;
  flex: 1;
  color: #999;
}

/* ==================== 横幅 ==================== */
.banner {
  height: 220rpx;
  margin: 24rpx;
  background: linear-gradient(135deg, #ff9a76 0%, #fecd71 50%, #ff6b6b 100%);
  border-radius: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-weight: 700;
  font-size: 34rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.25);
  position: relative;
  overflow: hidden;
}
.banner::after {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 50%;
}

/* ==================== 分类导航入口 ==================== */
.category-nav {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 24rpx;
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.cat-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}
.cat-nav-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.cat-nav-text {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

/* ==================== 排序标签 ==================== */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 32rpx 24rpx 16rpx;
  color: #1a1a1a;
}
.sort-tabs {
  font-size: 26rpx;
}
.sort-item {
  margin-left: 12rpx;
  color: #999;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  transition: all 0.2s;
}
.sort-item.active {
  color: #fff;
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  box-shadow: 0 4rpx 12rpx rgba(255, 71, 87, 0.25);
}

/* ==================== 骑手端：状态卡片 ==================== */
.status-card {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(102, 126, 234, 0.3);
}
.status-card .text-gray { color: rgba(255,255,255,0.7) !important; }

/* 骑手数据卡片 */
.stats-grid {
  margin: 0 24rpx;
}
.stat-box {
  align-items: center;
  padding: 32rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}
.stat-box .text-primary { color: #ff4757; }

/* 骑手任务列表 */
.task-list {
  padding: 0 24rpx;
}

/* ==================== 店铺列表容器 ==================== */
.shop-list {
  padding: 0 24rpx;
}
