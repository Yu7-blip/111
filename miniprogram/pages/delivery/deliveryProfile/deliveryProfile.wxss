.profile-container { padding: 0; padding-bottom: 40rpx; }

/* 头部视觉 (深色商务风) */
.rider-header {
  background: #3b424c;
  padding: 40rpx 40rpx 100rpx; 
  color: #fff;
  align-items: center;
}
.avatar {
  width: 130rpx; height: 130rpx;
  border-radius: 12rpx; /* 骑手用方头像显得更职业 */
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  background: #f0f0f0;
}
.nickname { font-size: 36rpx; }
.rider-id, .vehicle { color: #a0a5ab; }
.level-tag {
  font-size: 20rpx;
  background: rgba(255, 215, 0, 0.2);
  color: #ffd700;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.5);
}

/* 悬浮考核卡片 */
.stats-card {
  margin: -60rpx 30rpx 30rpx;
  padding: 40rpx 0;
  z-index: 10;
  position: relative;
}
.stat-item { align-items: center; border-right: 1rpx solid #f5f5f5; }
.stat-item:last-child { border-right: none; }
.stat-val { font-size: 44rpx; }

/* 菜单列表复用普通用户的样式 */
.menu-list { padding: 0 30rpx; margin: 0 30rpx; }
.menu-item { padding: 30rpx 0; background: transparent; }
.menu-icon { font-size: 32rpx; margin-right: 20rpx; }
.menu-text { font-size: 30rpx; color: #333; }
.arrow { font-size: 32rpx; }

/* 退出按钮 */
.logout-btn {
  margin: 60rpx 30rpx 30rpx;
  color: #3b424c;
  text-align: center;
  padding: 30rpx 0;
  font-weight: bold;
  font-size: 30rpx;
}