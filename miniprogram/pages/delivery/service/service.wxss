.type-row { gap: 20rpx; flex-wrap: wrap; }
.type-tag { padding: 14rpx 28rpx; border-radius: 30rpx; background: #f5f5f5; font-size: 26rpx; color: #666; }
.type-tag.active { background: #ff6b6b; color: #fff; }
.feedback-input { width: 100%; min-height: 200rpx; padding: 20rpx; border-radius: 12rpx; border: 1rpx solid #eee; font-size: 28rpx; background: #fafafa; }

/* 反馈历史 */
.feedback-item { padding: 16rpx 0; }
.tag { padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.tag-warn { background: #fff3e0; color: #e65100; }
.tag-danger { background: #ffebee; color: #c62828; }
.tag-info { background: #e3f2fd; color: #1565c0; }
.tag-success { background: #e8f5e9; color: #2e7d32; }
.tag-pending { background: #fff8e1; color: #f57f17; }
.reply-box { background: #fff5f5; padding: 16rpx; border-radius: 12rpx; border-left: 6rpx solid #ff6b6b; }

.text-center { text-align: center; }
.py-20 { padding-top: 20rpx; padding-bottom: 20rpx; }
