.container { padding: 0; padding-bottom: 40rpx; }

/* 余额卡片 */
.balance-card {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  padding: 60rpx 40rpx 80rpx;
  color: #fff;
  align-items: center;
}
.balance-card .label { font-size: 26rpx; opacity: 0.9; }
.amount-wrap { align-items: baseline; margin: 20rpx 0 40rpx; }
.amount-wrap .symbol { font-size: 40rpx; margin-right: 10rpx; }
.amount-wrap .amount { font-size: 80rpx; font-weight: bold; }
.withdraw-btn {
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid #fff;
  padding: 12rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 统计网格 */
.stats-grid { margin: -40rpx 30rpx 30rpx; padding: 40rpx 0; position: relative; z-index: 10; }
.stat-item { align-items: center; }
.stat-val { font-size: 36rpx; color: #333; }
.divider-v { width: 2rpx; height: 40rpx; background: #eee; }

/* 明细列表 */
.detail-section { padding: 0 30rpx; }
.section-title { padding: 20rpx 0; }
.detail-list { padding: 0 30rpx; }
.detail-item { padding: 30rpx 0; position: relative; }
.align-end { align-items: flex-end; }
.text-success { color: #52c41a; }
.order-time { font-family: monospace; }

/* 列表内部分割线 */
.detail-item .divider {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 1rpx; background: #f5f5f5;
}