.pt-90 { padding-top: 90rpx; }

/* 吸顶 Tab */
.tabs {
  position: fixed; top: 0; left: 0; right: 0;
  height: 88rpx; background: #fff; z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.tab-item {
  flex: 1; text-align: center; line-height: 88rpx;
  font-size: 28rpx; color: #666; position: relative;
}
.tab-item.active { color: #ff6b6b; font-weight: bold; }
.tab-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%;
  transform: translateX(-50%); width: 40rpx; height: 6rpx;
  background: #ff6b6b; border-radius: 4rpx;
}
.badge {
  background: #ee0a24; color: #fff;
  font-size: 20rpx; padding: 2rpx 10rpx;
  border-radius: 20rpx; vertical-align: super;
  margin-left: 4rpx;
}

/* 任务卡片 */
.task-list { padding: 20rpx; }
.task-card { padding: 30rpx; }
.text-danger { color: #ee0a24; font-weight: bold; }

/* 路线复用 (保持和 lobby 一致) */
.route-info { position: relative; padding: 10rpx 0; }
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; z-index: 2; position: relative; }
.dot.pick { background-color: #1890ff; }
.dot.drop { background-color: #ff6b6b; }
.route-line { position: absolute; left: 7rpx; top: 40rpx; bottom: 40rpx; width: 2rpx; background-color: #e0e0e0; z-index: 1; }

/* 工具图标 */
.icon-btn {
  width: 60rpx; height: 60rpx;
  background: #f5f5f5; border-radius: 50%;
  text-align: center; line-height: 60rpx;
  font-size: 30rpx;
}

/* 底部按钮 */
.footer { align-items: center; }
.btn-primary-small {
  background: #ff6b6b; color: #fff;
  padding: 16rpx 40rpx; border-radius: 40rpx;
  font-weight: bold; font-size: 28rpx;
}
.empty-state { align-items: center; padding-top: 100rpx; }