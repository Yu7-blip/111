<view class="container pt-90">
  
  <view class="tabs flex-row">
    <view class="tab-item {{currentTab === 'pickup' ? 'active' : ''}}" bindtap="switchTab" data-tab="pickup">
      待取餐 <text class="badge" wx:if="{{pickupCount > 0}}">{{pickupCount}}</text>
    </view>
    <view class="tab-item {{currentTab === 'delivering' ? 'active' : ''}}" bindtap="switchTab" data-tab="delivering">
      配送中 <text class="badge" wx:if="{{deliveringCount > 0}}">{{deliveringCount}}</text>
    </view>
  </view>

  <view class="task-list">
    <view class="card task-card" wx:for="{{taskList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      
      <view class="header flex-row space-between">
        <text class="font-bold font-32">#{{item.orderNo}}</text>
        <text class="time-limit {{item.isTimeout ? 'text-danger' : 'text-primary'}}">
          {{item.isTimeout ? '已超时' : '要求 ' + item.requireTime + ' 前送达'}}
        </text>
      </view>
      
      <view class="divider"></view>
      
      <view class="route-info flex-col">
        
        <view class="route-item flex-row space-between">
          <view class="flex-row flex-1">
            <view class="dot pick"></view>
            <view class="flex-col ml-20">
              <text class="font-bold font-28">{{item.shopName}}</text>
              <text class="text-gray font-24 mt-10">距您 {{item.distanceToShop}}km</text>
            </view>
          </view>
          <view class="tool-icons flex-row" wx:if="{{currentTab === 'pickup'}}" catchtap="preventBubble">
            <view class="icon-btn" catchtap="openMap" data-lat="{{item.shopLat}}" data-lng="{{item.shopLng}}" data-name="{{item.shopName}}">🗺️</view>
            <view class="icon-btn ml-20" catchtap="callPhone" data-phone="{{item.shopPhone}}">📞</view>
          </view>
        </view>
        
        <view class="route-line"></view>
        
        <view class="route-item flex-row space-between mt-20">
          <view class="flex-row flex-1">
            <view class="dot drop"></view>
            <view class="flex-col ml-20">
              <text class="font-bold font-28">{{item.deliveryAddress}}</text>
              <text class="text-gray font-24 mt-10">距商家 {{item.deliveryDistance}}km</text>
            </view>
          </view>
          <view class="tool-icons flex-row" wx:if="{{currentTab === 'delivering'}}" catchtap="preventBubble">
            <view class="icon-btn" catchtap="openMap" data-lat="{{item.userLat}}" data-lng="{{item.userLng}}" data-name="{{item.deliveryAddress}}">🗺️</view>
            <view class="icon-btn ml-20" catchtap="callPhone" data-phone="{{item.userPhone}}">📞</view>
          </view>
        </view>
        
      </view>
      
      <view class="divider"></view>
      
      <view class="footer flex-row space-between" catchtap="preventBubble">
        <text class="text-gray font-28">预估收入 ¥{{item.fee}}</text>
        <view class="btn-primary-small" wx:if="{{currentTab === 'pickup'}}" catchtap="confirmPickup" data-id="{{item.id}}">
          我已取餐
        </view>
        <view class="btn-primary-small" wx:if="{{currentTab === 'delivering'}}" catchtap="confirmDelivery" data-id="{{item.id}}">
          确认送达
        </view>
      </view>
      
    </view>

    <view class="empty-state flex-col" wx:if="{{taskList.length === 0}}">
      <text class="text-gray mt-40">暂无相关任务</text>
    </view>
  </view>
</view>