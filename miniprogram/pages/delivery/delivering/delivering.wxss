.delivering-container {
  width: 100vw;
  height: 100vh;
  position: relative;
}

.delivery-map {
  width: 100%;
  height: 100%;
}

/* 悬浮卡片样式 */
.info-card-wrap {
  position: absolute;
  bottom: 40rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 100;
}

.info-card {
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

.address-label {
  width: 40rpx;
  height: 40rpx;
  border-radius: 6rpx;
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  line-height: 40rpx;
}
.address-label.pick { background: #1890ff; }
.address-label.drop { background: #ff6b6b; }

.call-btn {
  width: 60rpx;
  height: 60rpx;
  background: #f5f5f5;
  border-radius: 50%;
  text-align: center;
  line-height: 60rpx;
  font-size: 28rpx;
}

.action-bar button {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  border-radius: 44rpx;
}

.mt-30 { margin-top: 30rpx; }

/* 阶段标签 */
.phase-tag {
  text-align: center;
  padding: 10rpx 0;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
}
.phase-tag.pickup {
  background: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #91d5ff;
}
.phase-tag.delivering {
  background: #fff1f0;
  color: #ff4d4f;
  border: 1rpx solid #ffa39e;
}

/* ==================== 导航指令浮层 ==================== */
.nav-instruction {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 100;
  background: rgba(0, 0, 0, 0.78);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  animation: navSlideIn 0.3s ease-out;
}

@keyframes navSlideIn {
  from { opacity: 0; transform: translateY(-20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.nav-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.nav-content {
  flex: 1;
  min-width: 0;
}

.nav-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-stats {
  margin-top: 6rpx;
  gap: 10rpx;
  align-items: center;
}

.nav-stat {
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
}

.nav-stat-dot {
  color: rgba(255, 255, 255, 0.3);
  font-size: 22rpx;
}

/* ==================== 客户坐标缺失警告 ==================== */
.no-coords-warning {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 101;
  background: rgba(255, 77, 79, 0.92);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(255, 77, 79, 0.4);
  animation: navSlideIn 0.3s ease-out;
}

.warning-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.warning-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.warning-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.warning-desc {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  line-height: 1.4;
}

.warning-addr {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  margin-top: 4rpx;
  padding: 8rpx 12rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 8rpx;
}