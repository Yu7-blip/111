.eval-item { padding: 20rpx 0; }
.eval-item.revoked { opacity: 0.5; }
.appeal-btn { padding: 8rpx 24rpx; border-radius: 20rpx; background: #fff0f0; color: #ff4757; font-size: 24rpx; border: 1rpx solid #ffd4d4; }
.dialog-mask { position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.4);z-index:99; }
.dialog-card { position:fixed;bottom:0;left:0;width:100%;background:#fff;border-radius:32rpx 32rpx 0 0;padding:48rpx 36rpx;z-index:100;box-sizing:border-box; }
.feedback-input { width:100%;min-height:160rpx;padding:20rpx;border-radius:12rpx;border:1rpx solid #eee;font-size:28rpx;background:#fafafa; }