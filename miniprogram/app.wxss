/* 全局背景与字体 */
page {
  background: linear-gradient(180deg, #f0f2f5 0%, #f7f8fa 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #2c2c2c;
  -webkit-font-smoothing: antialiased;
}

/* ==================== 布局工具 ==================== */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.space-between { justify-content: space-between; }
.space-around { justify-content: space-around; }
.items-start { align-items: flex-start; }
.items-end { align-items: flex-end; }
.justify-center { justify-content: center; }

/* ==================== 卡片系统（三层阴影立体感）==================== */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04),
              0 1rpx 4rpx rgba(0, 0, 0, 0.02);
  transition: all 0.2s ease;
}
/* 悬浮卡片（更突出） */
.card-raised {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08),
              0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
/* 嵌入卡片 */
.card-inset {
  background: #f7f8fa;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* ==================== 主题色系 ==================== */
.text-primary { color: #ff4757; }
.text-muted { color: #c0c4cc; }
.text-gray { color: #8c8c8c; }
.text-dark { color: #2c2c2c; }
.text-warning { color: #faad14; }
.text-success { color: #52c41a; }

.bg-primary { background: #ff4757; }
.bg-warm { background: linear-gradient(135deg, #fff5f5 0%, #fff0e6 100%); }
.bg-cool { background: linear-gradient(135deg, #f0f5ff 0%, #e6f7ff 100%); }

/* ==================== 按钮 ==================== */
.btn-primary {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  color: #fff;
  border-radius: 50rpx;
  font-weight: 600;
  font-size: 30rpx;
  padding: 22rpx 48rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.2s ease;
}
.btn-outline {
  background: #fff;
  color: #ff4757;
  border: 2rpx solid #ff4757;
  border-radius: 50rpx;
  font-weight: 600;
  font-size: 28rpx;
  padding: 18rpx 40rpx;
  text-align: center;
}
.btn-sm {
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
}

/* ==================== 字体层级 ==================== */
.font-20 { font-size: 20rpx; }
.font-22 { font-size: 22rpx; }
.font-24 { font-size: 24rpx; }
.font-26 { font-size: 26rpx; }
.font-28 { font-size: 28rpx; }
.font-30 { font-size: 30rpx; }
.font-32 { font-size: 32rpx; }
.font-36 { font-size: 36rpx; }
.font-40 { font-size: 40rpx; }
.font-48 { font-size: 48rpx; }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }

/* ==================== 间距工具 ==================== */
.mt-6 { margin-top: 6rpx; }
.mt-10 { margin-top: 10rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-16 { margin-left: 16rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }
.p-16 { padding: 16rpx; }
.p-20 { padding: 20rpx; }
.p-24 { padding: 24rpx; }
.px-20 { padding-left: 20rpx; padding-right: 20rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }

/* ==================== 文本工具 ==================== */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.text-center { text-align: center; }
.text-right { text-align: right; }

/* ==================== 价格 ==================== */
.price {
  color: #ee0a24;
  font-weight: 700;
  font-size: 34rpx;
  letter-spacing: -1rpx;
}
.price::before {
  content: '¥';
  font-size: 24rpx;
  font-weight: 600;
}

/* ==================== 分隔线 ==================== */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 16rpx 0;
}
.divider-v {
  display: inline-block;
  width: 1rpx;
  height: 20rpx;
  background: #e8e8e8;
  margin: 0 16rpx;
  vertical-align: middle;
}

/* ==================== 标签/徽标 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-red {
  background: #fff0f0;
  color: #ff4757;
  border: 1rpx solid #ffd4d4;
}
.tag-orange {
  background: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffe7ba;
}
.tag-green {
  background: #f0fff0;
  color: #52c41a;
  border: 1rpx solid #c8f0c8;
}
.tag-blue {
  background: #f0f5ff;
  color: #1890ff;
  border: 1rpx solid #c8e0ff;
}

/* ==================== 导航/箭头 ==================== */
.arrow-right {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid #c0c4cc;
  border-right: 3rpx solid #c0c4cc;
  transform: rotate(45deg);
}

/* ==================== 空状态 ==================== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-wrap image {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.4;
}
.empty-wrap text {
  font-size: 26rpx;
  color: #bbb;
  margin-top: 24rpx;
}

/* ==================== 安全区 ==================== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
