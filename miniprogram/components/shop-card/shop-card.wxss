.shop-card {
  background: #fff;
  padding: 20rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04),
              0 1rpx 4rpx rgba(0, 0, 0, 0.02);
  position: relative;
  overflow: hidden;
}
.shop-card:active {
  transform: scale(0.985);
  transition: transform 0.15s ease;
}

.shop-img-wrap {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.shop-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}
.shop-badge {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(255, 71, 87, 0.3);
}

.shop-body {
  overflow: hidden;
}
.shop-name {
  font-size: 32rpx;
  color: #1a1a1a;
  line-height: 1.2;
}

.shop-meta {
  align-items: center;
}
.rating-text {
  color: #faad14;
  font-size: 24rpx;
}
.sales-text {
  color: #b0b0b0;
}

.shop-footer {
  align-items: center;
}
.shop-tags {
  flex-wrap: wrap;
}

.distance-text {
  color: #8c8c8c;
  font-weight: 500;
}
.distance-icon {
  font-size: 22rpx;
}
