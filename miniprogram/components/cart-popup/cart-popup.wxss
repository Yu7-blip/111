@import "/app.wxss";

.cart-popup-container {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 90;
}
.mask {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
}
.popup-content {
  position: absolute; bottom: 0; left: 0; width: 100%;
  background: #fff; border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%); transition: transform 0.3s ease;
}
.popup-content.slide-up { transform: translateY(0); }

.popup-header {
  padding: 30rpx; background: #f9f9f9; border-radius: 24rpx 24rpx 0 0;
}
.cart-scroll { max-height: 50vh; padding: 0 30rpx; }
.cart-item { padding: 30rpx 0; border-bottom: 1rpx solid #f5f5f5; align-items: center; }
.price { color: #ee0a24; font-weight: bold; width: 100rpx; text-align: right; }
.mr-30 { margin-right: 30rpx; }

/* 步进器复用 */
.stepper { align-items: center; }
.step-btn { width: 40rpx; height: 40rpx; border-radius: 50%; text-align: center; line-height: 36rpx; font-weight: bold; }
.step-btn.plus { background: #ff6b6b; color: #fff; }
.step-btn.minus { border: 2rpx solid #e0e0e0; color: #666; }
.count { margin: 0 20rpx; font-size: 28rpx; }
/* 可点击编辑的数量 */
.count-tappable {
  border: 1rpx dashed #ccc;
  border-radius: 10rpx;
  padding: 4rpx 10rpx;
  min-width: 48rpx;
  text-align: center;
  background: #fafafa;
}
.count-tappable:active {
  border-color: #ff6b6b;
  background: #fff5f5;
}
/* 数量输入框 */
.count-input {
  width: 78rpx;
  height: 44rpx;
  border: 2rpx solid #ff6b6b;
  border-radius: 10rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin: 0 10rpx;
  padding: 0 4rpx;
}